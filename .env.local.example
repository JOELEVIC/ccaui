# Canonical site URL for SEO (metadata, sitemap, Open Graph). Production: https://cameroonchessacademy.com
# NEXT_PUBLIC_APP_URL=https://cameroonchessacademy.com

# Product name in header and metadata (default: DChessAcademy)
# NEXT_PUBLIC_APP_NAME=DChessAcademy

# GraphQL endpoint (optional; defaults: production → https://blacksilvergroups.xyz/api/graphql, dev → http://localhost:3000/api/graphql)
# NEXT_PUBLIC_GRAPHQL_URI=http://localhost:3000/api/graphql
# For live play (Vs Human): point to CCA on Render, e.g. https://cca-api-xxx.onrender.com/graphql
# NEXT_PUBLIC_GRAPHQL_URI=https://cca-api-xxx.onrender.com/graphql

# CCA Game Play API (live games: mutations + graphql-ws subscriptions). Used for Vs Human only.
# Production (default): https://chessliveapi.blacksilvergroups.xyz/graphql
# Dev (CCA running locally): http://localhost:4000/graphql
# NEXT_PUBLIC_GAME_API_URI=https://chessliveapi.blacksilvergroups.xyz/graphql
